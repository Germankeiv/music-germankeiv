<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
  <title>Stream-safe Music</title>
  <link rel="stylesheet" href="assets/styles.css" />
</head>
<body>
  <div class="app">
    <aside class="sidebar">
      <div class="brand">
        <div class="logo">♪</div>
        <div>
          <div class="brandTitle">Stream-safe</div>
          <div class="brandSub">No ads, GitHub Pages</div>
        </div>
      </div>

      <nav class="nav">
        <button class="navBtn active" data-view="library">Library</button>
        <button class="navBtn" data-view="queue">Queue</button>
        <button class="navBtn" data-view="about">About</button>
      </nav>

      <div class="tips">
        <div class="tipTitle">Autoplay note</div>
        <div class="tipText">
          Most browsers block autoplay with sound. Tap Play once to start.
        </div>
      </div>
    </aside>

    <main class="main">
      <header class="topbar">
        <div class="searchWrap">
          <input id="searchInput" type="search" placeholder="Search songs, artists, tags..." autocomplete="off" />
          <span class="searchHint">Press “/” to search</span>
        </div>
        <div class="topActions">
          <button id="shuffleAllBtn" class="ghost">Shuffle all</button>
          <button id="playAllBtn" class="primary">Play all</button>
        </div>
      </header>

      <section class="content">
        <div id="view-library" class="view active">
          <h1>Library</h1>
          <div id="libraryMeta" class="meta"></div>
          <div id="tracksGrid" class="grid"></div>
        </div>

        <div id="view-queue" class="view">
          <h1>Queue</h1>
          <div class="meta">Your upcoming tracks.</div>
          <div id="queueList" class="list"></div>
          <div class="row">
            <button id="clearQueueBtn" class="ghost">Clear queue</button>
            <button id="saveQueueBtn" class="ghost">Export queue (JSON)</button>
          </div>
        </div>

        <div id="view-about" class="view">
          <h1>About</h1>
          <p>
            This is a static music player you can host on GitHub Pages.
            Add only music you have the rights to share.
          </p>
          <ul>
            <li>Keyboard: Space = play/pause, N = next, P = previous, / = focus search</li>
            <li>Mobile: use the player controls at bottom</li>
          </ul>
        </div>
      </section>

      <footer class="playerBar">
        <div class="nowPlaying">
          <div class="cover" id="coverBox">♫</div>
          <div class="npText">
            <div id="npTitle" class="npTitle">Nothing playing</div>
            <div id="npSub" class="npSub">Tap Play</div>
          </div>
        </div>

        <div class="transport">
          <div class="btnRow">
            <button id="prevBtn" class="iconBtn" title="Previous">⏮</button>
            <button id="playBtn" class="iconBtn play" title="Play/Pause">▶</button>
            <button id="nextBtn" class="iconBtn" title="Next">⏭</button>
            <button id="loopBtn" class="iconBtn" title="Loop">🔁</button>
            <button id="shuffleBtn" class="iconBtn" title="Shuffle">🔀</button>
          </div>

          <div class="seekRow">
            <span id="timeNow" class="time">0:00</span>
            <input id="seek" type="range" min="0" max="1000" value="0" />
            <span id="timeTotal" class="time">0:00</span>
          </div>
        </div>

        <div class="rightControls">
          <button id="muteBtn" class="ghost small">Mute</button>
          <input id="volume" type="range" min="0" max="1" step="0.01" value="1" />
        </div>

        <audio id="audio" preload="metadata" playsinline></audio>
      </footer>
    </main>
  </div>

  <script src="assets/app.js"></script>
</body>
</html>


